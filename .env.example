# Backend
APP_NAME=ResumeFit
ENVIRONMENT=development
DATABASE_URL=sqlite:///./resumefit.db
CORS_ORIGINS=http://localhost:5173

# Local development placeholder only. Replace in your private .env.
JWT_SECRET_KEY=change_me_for_local_dev_secret_please_replace
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI-compatible AI provider
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=your_api_key_here
AI_MODEL=your_model_name
AI_TIMEOUT_SECONDS=60
AI_MONTHLY_CALL_LIMIT=100
AI_INPUT_TOKEN_PRICE_PER_1K=0
AI_OUTPUT_TOKEN_PRICE_PER_1K=0

# Frontend
VITE_API_BASE_URL=http://localhost:8000
